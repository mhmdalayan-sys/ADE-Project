package com.example.audioexfil

import android.app.Activity
import android.content.Intent
import android.media.AudioFormat
import android.media.AudioManager
import android.media.AudioTrack
import android.net.Uri
import android.os.Bundle
import android.widget.Button
import android.widget.TextView
import java.io.ByteArrayOutputStream
import java.io.InputStream
import kotlin.math.PI
import kotlin.math.sin

class MainActivity : Activity() {

    private lateinit var statusText: TextView
    private var selectedFileBytes: ByteArray? = null
    private var selectedExtension: String = "bin"

    companion object {
        const val SAMPLE_RATE = 44100
        const val BIT_DURATION_SEC = 0.15 // Matches decoder_phone_laptop.py

        // Frequencies exactly matching decoder_phone_laptop.py
        const val START_FREQ = 1500.0
        const val FREQ0 = 2000.0
        const val FREQ1 = 3000.0
        const val END_FREQ = 4000.0

        const val MARKER_DURATION_SEC = 0.4
        const val REQ_PICK_FILE = 1001
    }

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(R.layout.activity_main)

        statusText = findViewById(R.id.statusText)
        val pickBtn: Button = findViewById(R.id.pickButton)
        val sendBtn: Button = findViewById(R.id.sendButton)

        pickBtn.setOnClickListener {
            val intent = Intent(Intent.ACTION_OPEN_DOCUMENT).apply {
                addCategory(Intent.CATEGORY_OPENABLE)
                type = "*/*"
            }
            startActivityForResult(intent, REQ_PICK_FILE)
        }

        sendBtn.setOnClickListener {
            val data = selectedFileBytes
            if (data == null) {
                statusText.text = "Pick a file first"
                return@setOnClickListener
            }
            Thread { transmitFile(data, selectedExtension) }.start()
        }
    }

    override fun onActivityResult(requestCode: Int, resultCode: Int, data: Intent?) {
        super.onActivityResult(requestCode, resultCode, data)
        if (requestCode == REQ_PICK_FILE && resultCode == Activity.RESULT_OK) {
            val uri: Uri? = data?.data
            if (uri != null) {
                Thread { loadFileFromUri(uri) }.start()
            }
        }
    }

    private fun loadFileFromUri(uri: Uri) {
        try {
            val ext = getExtensionFromUri(uri)
            val bytes = readAllBytes(contentResolver.openInputStream(uri)!!)
            selectedFileBytes = bytes
            selectedExtension = ext
            runOnUiThread {
                statusText.text = "Loaded file (${bytes.size} bytes, .$ext)"
            }
        } catch (e: Exception) {
            runOnUiThread {
                statusText.text = "Error reading file: ${e.message}"
            }
        }
    }

    private fun getExtensionFromUri(uri: Uri): String {
        val name = uri.lastPathSegment ?: "file.bin"
        val idx = name.lastIndexOf('.')
        return if (idx != -1 && idx < name.length - 1) {
            name.substring(idx + 1).take(8)
        } else {
            "bin"
        }
    }

    private fun readAllBytes(input: InputStream): ByteArray {
        input.use { ins ->
            val buffer = ByteArrayOutputStream()
            val tmp = ByteArray(4096)
            while (true) {
                val read = ins.read(tmp)
                if (read == -1) break
                buffer.write(tmp, 0, read)
            }
            return buffer.toByteArray()
        }
    }

    private fun transmitFile(data: ByteArray, ext: String) {
        try {
            runOnUiThread { statusText.text = "Transmitting..." }

            val frame = buildFrame(data, ext)

            // Calculate buffer size for streaming
            val minBufSize = AudioTrack.getMinBufferSize(
                SAMPLE_RATE,
                AudioFormat.CHANNEL_OUT_MONO,
                AudioFormat.ENCODING_PCM_16BIT
            )

            val track = AudioTrack(
                AudioManager.STREAM_MUSIC,
                SAMPLE_RATE,
                AudioFormat.CHANNEL_OUT_MONO,
                AudioFormat.ENCODING_PCM_16BIT,
                minBufSize.coerceAtLeast(32768),
                AudioTrack.MODE_STREAM // CRITICAL: STREAM mode prevents memory crashes
            )

            track.play()

            // 1. Start Marker (1500Hz)
            writeTone(track, START_FREQ, MARKER_DURATION_SEC)

            // 2. Tiny silence post-marker (Matches decoder's 0.05 step logic)
            writeTone(track, 0.0, 0.05)

            // 3. Data Bits
            for (byte in frame) {
                for (i in 7 downTo 0) {
                    val bit = (byte.toInt() shr i) and 1
                    val freq = if (bit == 0) FREQ0 else FREQ1
                    writeTone(track, freq, BIT_DURATION_SEC)
                }
            }

            // 4. End Marker (4000Hz)
            writeTone(track, END_FREQ, MARKER_DURATION_SEC)

            // Stop and release
            track.stop()
            track.release()

            runOnUiThread { statusText.text = "Transmission complete" }
        } catch (e: Exception) {
            runOnUiThread { statusText.text = "Error: ${e.message}" }
        }
    }

    private fun buildFrame(data: ByteArray, ext: String): ByteArray {
        val magic = "AGAP".toByteArray(Charsets.US_ASCII)
        val size = data.size
        val sizeBytes = byteArrayOf(
            ((size shr 24) and 0xFF).toByte(),
            ((size shr 16) and 0xFF).toByte(),
            ((size shr 8) and 0xFF).toByte(),
            (size and 0xFF).toByte()
        )
        val extBytes = ext.toByteArray(Charsets.US_ASCII).let { if (it.size > 8) it.copyOf(8) else it }
        val extLen = extBytes.size.toByte()
        return magic + sizeBytes + byteArrayOf(extLen) + extBytes + data
    }

    private var currentPhase = 0.0

    private fun writeTone(track: AudioTrack, freq: Double, durationSec: Double) {
        val samplesCount = (SAMPLE_RATE * durationSec).toInt()
        if (samplesCount <= 0) return

        val buffer = ShortArray(samplesCount)
        if (freq > 0) {
            val phaseIncrement = 2.0 * PI * freq / SAMPLE_RATE
            for (i in 0 until samplesCount) {
                currentPhase += phaseIncrement
                // Keep phase within a reasonable range
                if (currentPhase > 2.0 * PI) currentPhase -= 2.0 * PI
                buffer[i] = (sin(currentPhase) * 32767 * 0.7).toInt().toShort()
            }
        } else {
            for (i in 0 until samplesCount) buffer[i] = 0
        }

        track.write(buffer, 0, buffer.size)
    }
}
